# ════════════════════════════════════════════════════════
# BintuNet Controller — Environment Variables
# Copy to .env.production and fill in your values.
# NEVER commit .env.production to git.
# ════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────
NODE_ENV=production
PORT=8080

# ── Auth ──────────────────────────────────────────────────
# Generate: openssl rand -hex 32
SESSION_SECRET=change_me_in_production

# Password to access the dashboard
BINTUNET_PASSWORD=bintunet

# ── Redis (shared between primary + backup VPS) ────────────
# Upstash free tier: https://upstash.com
# Format: redis://default:password@host:port
# Leave empty to use local in-memory only (single-node mode)
REDIS_URL=

# ── High Availability ─────────────────────────────────────
# Set to "primary" on the main VPS, "backup" on the standby
VPS_ROLE=primary

# Backup only: URL of primary VPS API (used by failover-watcher)
PRIMARY_API_URL=http://PRIMARY_HOST:8080

# Failover timing (ms)
FAILOVER_POLL_MS=5000
FAILOVER_TIMEOUT_MS=15000

# ── Adaptive Bitrate HLS ──────────────────────────────────
# Set to "true" to start an HLS encoder alongside RTMP
HLS_ENABLED=false

# Directory for HLS segments (must have sufficient disk space)
# Each active stream uses ~50MB/min of segments (auto-pruned to 6×4s)
HLS_SEGMENT_DIR=/tmp/hls

# ── Cloudflare R2 / S3 (CDN origin) ──────────────────────
# Get from Cloudflare Dashboard → R2 → Manage R2 API Tokens
# Format: https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_ENDPOINT=

# R2 API token access key
R2_ACCESS_KEY_ID=

# R2 API token secret key
R2_SECRET_ACCESS_KEY=

# R2 bucket name (create at dash.cloudflare.com → R2)
R2_BUCKET=bintunet-hls

# CDN base URL (Cloudflare custom domain pointing to your R2 bucket)
# Example: https://live.yourdomain.com
CDN_BASE_URL=

# ── YouTube API ───────────────────────────────────────────
# For live viewer/subscriber count polling
# Get from console.cloud.google.com → APIs → YouTube Data API v3
YOUTUBE_API_KEY=

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=info

# ── Frontend (build-time only) ────────────────────────────
# Set at build time by vite.config.ts
# PORT=5000
# BASE_PATH=/
